<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Candidate Dashboard - JobWhisper</title>


    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>

    <div class="dashboard-layout">
        <%- include('partials/dashboard-sidebar', { activePage: 'dashboard' }) %>

            <!-- MAIN CONTENT -->
            <main class="dash-main">
                <%- include('partials/dashboard-header', { title: 'Candidate Dashboard' }) %>

                    <div class="dash-content">
                        <div
                            style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem;">
                            <div>
                                <h1 class="dash-title">Hello, <%= user.profile.firstName %>!</h1>
                                <p class="dash-subtitle" style="margin-bottom: 0;">You have <%= applications.length %>
                                        active
                                        applications.</p>
                            </div>
                            <a href="/jobs" class="btn btn-primary"><i data-lucide="search"></i> Browse More Jobs</a>
                        </div>

                        <!-- Stats -->
                        <div class="dash-stats-grid">
                            <div class="stat-card">
                                <div class="stat-icon"><i data-lucide="briefcase"></i></div>
                                <div class="stat-info">
                                    <h3>
                                        <%= stats.appliedJobs %>
                                    </h3>
                                    <p>Applied Jobs</p>
                                </div>
                            </div>

                            <div class="stat-card orange">
                                <div class="stat-icon"><i data-lucide="bookmark"></i></div>
                                <div class="stat-info">
                                    <h3>
                                        <%= stats.savedJobs %>
                                    </h3>
                                    <p>Saved Jobs</p>
                                </div>
                            </div>

                            <div class="stat-card green">
                                <div class="stat-icon"><i data-lucide="eye"></i></div>
                                <div class="stat-info">
                                    <h3>
                                        <%= stats.profileViews %>
                                    </h3>
                                    <p>Profile Views</p>
                                </div>
                            </div>
                        </div>

                        <!-- Recent Applications -->
                        <div class="dash-section-card">
                            <div class="dash-section-header">
                                <h3>Recent Applications</h3>
                                <a href="#"
                                    style="color: var(--color-secondary); font-weight: 600; font-size: 0.9rem;">View All
                                    <i data-lucide="arrow-right" style="width: 16px; vertical-align: middle;"></i></a>
                            </div>
                            <div class="table-container">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Job Title</th>
                                            <th>Date Applied</th>
                                            <th>Status</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (applications && applications.length> 0) { %>
                                            <% applications.forEach(app=> { %>
                                                <tr>
                                                    <td>
                                                        <div class="job-title-cell">
                                                            <div class="job-logo"><i data-lucide="briefcase"></i></div>
                                                            <div>
                                                                <p
                                                                    style="font-weight: 600; color: var(--color-primary); margin-bottom: 0.2rem;">
                                                                    <% if (app.job) { %>
                                                                        <a href="/job-detail/<%= app.job._id %>"
                                                                            style="color: inherit; text-decoration: none;">
                                                                            <%= app.job.title %>
                                                                        </a>
                                                                        <% } else { %>
                                                                            Job Unavailable
                                                                            <% } %>
                                                                </p>
                                                                <p
                                                                    style="font-size: 0.85rem; color: var(--text-light);">
                                                                    <%= app.job ? app.job.company : '' %>
                                                                </p>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <%= new Date(app.appliedAt).toLocaleDateString() %>
                                                    </td>
                                                    <td><span
                                                            class="status-badge <%= 'status-' + (app.status ? app.status.toLowerCase() : 'pending') %>">
                                                            <%= app.status || 'Pending' %>
                                                        </span></td>
                                                    <td>
                                                        <button class="btn btn-outline"
                                                            style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">View
                                                            Details</button>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="4" style="padding: 0;">
                                                                <div style="text-align: center; padding: 4rem 2rem;">
                                                                    <div
                                                                        style="width: 60px; height: 60px; background: var(--bg-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--color-primary);">
                                                                        <i data-lucide="briefcase"></i>
                                                                    </div>
                                                                    <h4
                                                                        style="color: var(--text-dark); margin-bottom: 0.5rem;">
                                                                        No applications yet</h4>
                                                                    <p
                                                                        style="color: var(--text-light); margin-bottom: 1.5rem;">
                                                                        You haven't applied to any jobs. Start your
                                                                        journey
                                                                        today!</p>
                                                                    <a href="/jobs"
                                                                        class="btn btn-primary btn-sm">Browse
                                                                        Jobs</a>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
            </main>

    </div>

    <script src="js/main.js"></script>
    <script>lucide.createIcons();</script>
</body>

</html>
<%- include('partials/header') %>

    <div class="dashboard-layout">
        <%- include('partials/dashboard-sidebar', { activePage: 'applicants' }) %>

            <!-- MAIN CONTENT -->
            <main class="dash-main">
                <%- include('partials/dashboard-header', { title: 'Job Applicants' }) %>

                    <div class="dash-content">
                        <h1 class="dash-title">Applicants for <%= job.title %>
                        </h1>
                        <p class="dash-subtitle">Review the candidates interested in this position.</p>

                        <div class="dash-section-card" style="margin-top: 2rem;">
                            <div class="table-container">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Candidate</th>
                                            <th>Email</th>
                                            <th>Applied On</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (applications && applications.length> 0) { %>
                                            <% applications.forEach(app=> { %>
                                                <tr>
                                                    <td>
                                                        <div style="display: flex; align-items: center; gap: 1rem;">
                                                            <div
                                                                style="width: 40px; height: 40px; border-radius: 50%; background: var(--bg-light); display: flex; align-items: center; justify-content: center; font-weight: 600; color: var(--color-primary);">
                                                                <%= (app.candidate.profile &&
                                                                    app.candidate.profile.firstName) ?
                                                                    app.candidate.profile.firstName.charAt(0) : '?' %>
                                                                    <%= (app.candidate.profile &&
                                                                        app.candidate.profile.lastName) ?
                                                                        app.candidate.profile.lastName.charAt(0) : '' %>
                                                            </div>
                                                            <p style="font-weight: 600; color: var(--text-dark);">
                                                                <%= (app.candidate.profile &&
                                                                    app.candidate.profile.firstName) ?
                                                                    app.candidate.profile.firstName : 'Unknown' %>
                                                                    <%= (app.candidate.profile &&
                                                                        app.candidate.profile.lastName) ?
                                                                        app.candidate.profile.lastName : '' %>
                                                            </p>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <%= app.candidate.email %>
                                                    </td>
                                                    <td>
                                                        <%= new Date(app.appliedAt).toLocaleDateString() %>
                                                    </td>
                                                    <td>
                                                        <form action="/application/<%= app._id %>/status" method="POST"
                                                            style="display: inline-block;">
                                                            <select name="status" class="form-control"
                                                                style="padding: 0.25rem; font-size: 0.85rem; height: auto;"
                                                                onchange="this.form.submit()">
                                                                <option value="Pending" <%=app.status==='Pending'
                                                                    ? 'selected' : '' %>
                                                                    >Pending</option>
                                                                <option value="Reviewed" <%=app.status==='Reviewed'
                                                                    ? 'selected' : '' %>
                                                                    >Reviewed</option>
                                                                <option value="Shortlisted"
                                                                    <%=app.status==='Shortlisted' ? 'selected' : '' %>
                                                                    >Shortlisted</option>
                                                                <option value="Rejected" <%=app.status==='Rejected'
                                                                    ? 'selected' : '' %>
                                                                    >Rejected</option>
                                                            </select>
                                                        </form>
                                                    </td>
                                                    <td>
                                                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                                            <a href="/candidate/<%= app.candidate._id %>/profile"
                                                                target="_blank" class="btn btn-primary"
                                                                style="padding: 0.35rem 0.75rem; font-size: 0.85rem; text-decoration: none;">View
                                                                Profile</a>
                                                            <% if (app.resumePath) { %>
                                                                <a href="<%= app.resumePath %>" target="_blank"
                                                                    class="btn btn-outline"
                                                                    style="padding: 0.35rem 0.75rem; font-size: 0.85rem; text-decoration: none;">Resume</a>
                                                                <% } %>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="5"
                                                                style="text-align: center; color: var(--text-light); padding: 2rem;">
                                                                No applicants yet for this position.
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
            </main>
    </div>

    <script src="/js/main.js"></script>
    <script>lucide.createIcons();</script>
    </body>

    </html>
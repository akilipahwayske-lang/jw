<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employer Dashboard - JobWhisper</title>


    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>

    <div class="dashboard-layout">
        <%- include('partials/dashboard-sidebar', { activePage: 'dashboard' }) %>

            <!-- MAIN CONTENT -->
            <main class="dash-main">
                <%- include('partials/dashboard-header', { title: 'Employer Dashboard' }) %>

                    <div class="dash-content">
                        <div
                            style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem;">
                            <div>
                                <h1 class="dash-title">Welcome back, <%= user.firstName %>!</h1>
                                <p class="dash-subtitle" style="margin-bottom: 0;">Here's an overview of your job
                                    postings and applicant pipeline.</p>
                            </div>
                            <a href="/post-job" class="btn btn-primary"><i data-lucide="plus"></i> Post a New Job</a>
                        </div>

                        <!-- Stats -->
                        <div class="dash-stats-grid">
                            <div class="stat-card blue">
                                <div class="stat-icon"><i data-lucide="briefcase"></i></div>
                                <div class="stat-info">
                                    <h3>
                                        <%= stats.activeJobs %>
                                    </h3>
                                    <p>Active Jobs</p>
                                </div>
                            </div>

                            <div class="stat-card orange">
                                <div class="stat-icon"><i data-lucide="users"></i></div>
                                <div class="stat-info">
                                    <h3>
                                        <%= stats.totalApplicants %>
                                    </h3>
                                    <p>Total Applicants</p>
                                </div>
                            </div>

                            <div class="stat-card green">
                                <div class="stat-icon"><i data-lucide="check-circle"></i></div>
                                <div class="stat-info">
                                    <h3>
                                        <%= stats.shortlisted %>
                                    </h3>
                                    <p>Shortlisted</p>
                                </div>
                            </div>
                        </div>

                        <!-- Recent Jobs -->
                        <div class="dash-section-card">
                            <div class="dash-section-header">
                                <h3 style="font-weight: 700; color: var(--color-primary);">Recent Job Postings</h3>
                                <a href="/post-job" class="btn btn-primary"
                                    style="padding: 0.5rem 1rem; font-size: 0.9rem;"><i data-lucide="plus"
                                        style="width: 16px;"></i> Post Job</a>
                            </div>
                            <div class="table-container">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Job Title</th>
                                            <th>Applications</th>
                                            <th>Posted Date</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (jobs && jobs.length> 0) { %>
                                            <% jobs.forEach(job=> { %>
                                                <tr>
                                                    <td>
                                                        <p style="font-weight: 600; color: var(--text-dark);"><a
                                                                href="/job-detail/<%= job._id %>"
                                                                style="color: inherit; text-decoration: none;">
                                                                <%= job.title %>
                                                            </a></p>
                                                        <p style="font-size: 0.85rem; color: var(--text-light);">
                                                            <%= job.type %> &bull; <%= job.location %>
                                                        </p>
                                                    </td>
                                                    <td><strong style="color: var(--color-primary);">
                                                            <%= (typeof applicationCounts !=='undefined' &&
                                                                applicationCounts[job._id.toString()]) ?
                                                                applicationCounts[job._id.toString()] : 0 %>
                                                        </strong> applicants</td>
                                                    <td>
                                                        <%= new Date(job.postedAt).toLocaleDateString() %>
                                                    </td>
                                                    <td><span class="status-badge status-active">Active</span></td>
                                                    <td>
                                                        <div style="display: flex; gap: 0.5rem;">
                                                            <a href="/employer/job/<%= job._id %>/applicants"
                                                                class="btn btn-outline" title="View Applicants"
                                                                style="padding: 0.35rem 0.5rem; text-decoration: none; display: flex; align-items: center; justify-content: center;"><i
                                                                    data-lucide="users"
                                                                    style="width: 16px; height: 16px;"></i></a>
                                                            <button class="btn btn-outline" title="Edit Job"
                                                                style="padding: 0.35rem 0.5rem;"><i data-lucide="edit"
                                                                    style="width: 16px; height: 16px;"></i></button>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="5" style="padding: 0;">
                                                                <div style="text-align: center; padding: 4rem 2rem;">
                                                                    <div
                                                                        style="width: 60px; height: 60px; background: var(--bg-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--color-primary);">
                                                                        <i data-lucide="plus-circle"></i>
                                                                    </div>
                                                                    <h4
                                                                        style="color: var(--text-dark); margin-bottom: 0.5rem;">
                                                                        No jobs posted yet</h4>
                                                                    <p
                                                                        style="color: var(--text-light); margin-bottom: 1.5rem;">
                                                                        Start hiring today by posting your first job
                                                                        opening.
                                                                    </p>
                                                                    <a href="/post-job"
                                                                        class="btn btn-primary btn-sm">Post a
                                                                        Job</a>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
            </main>
    </div>

    <script src="js/main.js"></script>
    <script>lucide.createIcons();</script>
</body>

</html>
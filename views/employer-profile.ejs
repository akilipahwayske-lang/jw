<%- include('partials/header') %>

    <div class="dashboard-layout">
        <%- include('partials/dashboard-sidebar', { activePage: 'profile' }) %>

            <!-- MAIN CONTENT -->
            <main class="dash-main">
                <%- include('partials/dashboard-header', { title: 'Company Profile' }) %>

                    <div class="dash-content">
                        <div style="max-width: 800px;">
                            <h1 class="dash-title">Company Settings</h1>
                            <p class="dash-subtitle">Manage your company branding and information displayed on job
                                posts.</p>

                            <form class="dash-section-card" action="/employer-profile" method="POST"
                                enctype="multipart/form-data" style="padding: 2rem;">
                                <div class="form-group">
                                    <label class="form-label">Company Logo</label>
                                    <div style="display: flex; align-items: center; gap: 2rem; margin-bottom: 1rem;">
                                        <div
                                            style="width: 100px; height: 100px; background: var(--bg-light); border-radius: var(--radius-md); border: 1px solid var(--border-color); display: flex; align-items: center; justify-content: center; overflow: hidden;">
                                            <% if (userProfile.companyLogo) { %>
                                                <img src="<%= userProfile.companyLogo %>" alt="Current Logo"
                                                    style="width: 100%; height: 100%; object-fit: contain;">
                                                <% } else { %>
                                                    <i data-lucide="image"
                                                        style="color: var(--text-light); width: 40px; height: 40px;"></i>
                                                    <% } %>
                                        </div>
                                        <div style="flex: 1;">
                                            <input type="file" name="logo" class="form-control" accept="image/*">
                                            <p
                                                style="font-size: 0.85rem; color: var(--text-light); margin-top: 0.5rem;">
                                                Recommended: Square image, max 2MB (PNG, JPG).</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Company Name</label>
                                    <input type="text" name="companyName" class="form-control"
                                        value="<%= userProfile.companyName || '' %>" required>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Company Bio / Description</label>
                                    <textarea name="bio" class="form-control"
                                        rows="4"><%= userProfile.bio || '' %></textarea>
                                </div>

                                <div style="margin-top: 2rem; display: flex; justify-content: flex-end;">
                                    <button type="submit" class="btn btn-primary">Save Changes</button>
                                </div>
                            </form>
                        </div>
                    </div>
            </main>
    </div>

    <script src="js/main.js"></script>
    <script>lucide.createIcons();</script>
    </body>

    </html>
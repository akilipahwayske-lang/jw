<%- include('partials/header') %>

    <!-- JOB HEADER -->
    <header class="job-header-bg">
        <div class="container job-header-content">
            <div class="job-logo-large">
                <i data-lucide="briefcase"></i>
            </div>
            <div class="job-title-wrapper">
                <h1>
                    <%= job.title %>
                </h1>
                <p>
                    <%= job.company %> &nbsp;|&nbsp; <i data-lucide="map-pin"
                            style="width: 16px; display:inline-block; vertical-align: middle;"></i>
                        <%= job.location %>
                </p>
                <div class="job-badges" style="margin-top: 1rem;">
                    <span class="badge" style="background: rgba(255,255,255,0.2); color: #fff;">
                        <%= job.type %>
                    </span>
                </div>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="container mb-2">
        <div class="job-detail-grid">

            <!-- LEFT COLUMN -->
            <div class="detail-card content-section">
                <h3>Job Description</h3>
                <p>
                    <%= job.description %>
                </p>

                <% if (job.requirements && job.requirements.length> 0) { %>
                    <h3>Requirements & Skills</h3>
                    <ul>
                        <% job.requirements.forEach(req=> { %>
                            <li><span>
                                    <%= req %>
                                </span></li>
                            <% }) %>
                    </ul>
                    <% } %>

                        <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border-color);">
                            <p style="font-weight: 600; margin-bottom: 1rem;">Share this job:</p>
                            <div style="display: flex; gap: 1rem;">
                                <button class="btn btn-outline" style="padding: 0.5rem;"><i
                                        data-lucide="facebook"></i></button>
                                <button class="btn btn-outline" style="padding: 0.5rem;"><i
                                        data-lucide="twitter"></i></button>
                                <button class="btn btn-outline" style="padding: 0.5rem;"><i
                                        data-lucide="linkedin"></i></button>
                                <button class="btn btn-outline" style="padding: 0.5rem;"><i data-lucide="link"></i> Copy
                                    Link</button>
                            </div>
                        </div>
            </div>

            <!-- RIGHT COLUMN (Sidebar) -->
            <div>

                <!-- Job Summary Widget -->
                <div class="detail-card" style="padding: 2rem;">
                    <h3
                        style="font-size: 1.25rem; color: var(--color-primary); margin-bottom: 1.5rem; font-family: 'Outfit', sans-serif;">
                        Job Summary</h3>

                    <div class="sidebar-info-item">
                        <div class="sidebar-info-icon"><i data-lucide="calendar"></i></div>
                        <div class="sidebar-info-content">
                            <h5>Date Posted</h5>
                            <p>
                                <%= new Date(job.postedAt).toLocaleDateString() %>
                            </p>
                        </div>
                    </div>

                    <div class="sidebar-info-item">
                        <div class="sidebar-info-icon"><i data-lucide="map-pin"></i></div>
                        <div class="sidebar-info-content">
                            <h5>Location</h5>
                            <p>
                                <%= job.location %>
                            </p>
                        </div>
                    </div>

                    <div class="sidebar-info-item">
                        <div class="sidebar-info-icon"><i data-lucide="banknote"></i></div>
                        <div class="sidebar-info-content">
                            <h5>Salary</h5>
                            <p>
                                <%= job.salary || 'Competitive' %>
                            </p>
                        </div>
                    </div>

                    <div style="margin-top: 2rem;">
                        <% if (!user) { %>
                            <a href="/login" class="btn btn-primary"
                                style="width: 100%; padding: 1rem; font-size: 1.1rem; margin-bottom: 1rem; text-decoration: none; text-align: center; display: block;">Login
                                to Apply</a>
                            <% } else if (user.role==='employer' ) { %>
                                <button class="btn btn-primary"
                                    style="width: 100%; padding: 1rem; font-size: 1.1rem; margin-bottom: 1rem;"
                                    disabled>Employers Cannot Apply</button>
                                <% } else { %>
                                    <form action="/apply/<%= job._id %>" method="POST" style="margin-bottom: 1rem;">
                                        <button type="submit" class="btn btn-primary"
                                            style="width: 100%; padding: 1rem; font-size: 1.1rem;">Apply for this
                                            Job</button>
                                    </form>
                                    <% } %>
                                        <button class="btn btn-outline" style="width: 100%; padding: 1rem;"><i
                                                data-lucide="bookmark"></i> Save Job</button>
                    </div>
                </div>

                <!-- Company Widget -->
                <div class="detail-card" style="padding: 2rem;">
                    <h3
                        style="font-size: 1.25rem; color: var(--color-primary); margin-bottom: 1.5rem; font-family: 'Outfit', sans-serif;">
                        About Company</h3>
                    <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem;">
                        <div
                            style="width: 50px; height: 50px; background: var(--bg-light); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: var(--color-primary); border: 1px solid var(--border-color);">
                            <i data-lucide="briefcase"></i>
                        </div>
                        <div>
                            <h4 style="color: var(--text-dark); font-size: 1.1rem;">
                                <%= job.company %>
                            </h4>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="container">
            <div class="footer-bottom" style="border-top: none;">
                <p>&copy; 2026 JobWhisper.co.ke. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="js/main.js"></script>
    <script>lucide.createIcons();</script>
    </body>

    </html>
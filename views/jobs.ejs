<%- include('partials/header') %>

    <!-- HEADER -->
    <div class="hero" style="padding: 4rem 0 3rem;">
        <div class="container">
            <h1 class="hero-title" style="font-size: 2.5rem; margin-bottom: 0.5rem;">Browse Open Positions</h1>
            <p class="hero-subtitle" style="margin-left: 0; text-align: left;">Find the most relevant jobs matching your
                criteria.</p>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <section class="container my-4">
        <div class="page-layout">

            <!-- SIDEBAR (Filters) -->
            <aside class="sidebar">
                <form id="filter-form" action="/jobs" method="GET">
                    <!-- Keyword -->
                    <div class="sidebar-widget">
                        <h4 class="sidebar-title"><i data-lucide="search"></i>Search Keyword</h4>
                        <div style="position: relative;">
                            <i data-lucide="search"
                                style="position: absolute; left: 10px; top: 11px; color: var(--text-light); width: 16px;"></i>
                            <input type="text" name="search" class="form-control" placeholder="Job title, keywords..."
                                style="padding-left: 35px;"
                                value="<%= (typeof query !== 'undefined' && query.search) ? query.search : '' %>">
                        </div>
                    </div>

                    <!-- Location -->
                    <div class="sidebar-widget">
                        <h4 class="sidebar-title"><i data-lucide="map-pin"></i>Location</h4>
                        <div style="position: relative;">
                            <i data-lucide="map-pin"
                                style="position: absolute; left: 10px; top: 11px; color: var(--text-light); width: 16px;"></i>
                            <input type="text" name="location" class="form-control" placeholder="City or region"
                                style="padding-left: 35px;"
                                value="<%= (typeof query !== 'undefined' && query.location) ? query.location : '' %>">
                        </div>
                    </div>

                    <!-- Category -->
                    <div class="sidebar-widget">
                        <h4 class="sidebar-title"><i data-lucide="grid"></i>Category</h4>
                        <label class="checkbox-label">
                            <input type="checkbox" name="cat" value="design" <%=(typeof query !=='undefined' &&
                                query.cat && query.cat.includes('design')) ? 'checked' : '' %>>
                            Design & Creative
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="cat" value="marketing" <%=(typeof query !=='undefined' &&
                                query.cat && query.cat.includes('marketing')) ? 'checked' : '' %>>
                            Marketing & Sales
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="cat" value="it" <%=(typeof query !=='undefined' && query.cat &&
                                query.cat.includes('it')) ? 'checked' : '' %>>
                            IT & Software
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="cat" value="medical" <%=(typeof query !=='undefined' &&
                                query.cat && query.cat.includes('medical')) ? 'checked' : '' %>>
                            Medical</label>
                    </div>

                    <!-- Job Type -->
                    <div class="sidebar-widget">
                        <h4 class="sidebar-title"><i data-lucide="briefcase"></i>Job Type</h4>
                        <label class="checkbox-label">
                            <input type="checkbox" name="type" value="Full-time" <%=(typeof query !=='undefined' &&
                                query.type && query.type.includes('Full-time')) ? 'checked' : '' %>>
                            Full Time
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="type" value="Part-time" <%=(typeof query !=='undefined' &&
                                query.type && query.type.includes('Part-time')) ? 'checked' : '' %>>
                            Part Time
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="type" value="Contract" <%=(typeof query !=='undefined' &&
                                query.type && query.type.includes('Contract')) ? 'checked' : '' %>>
                            Contract
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" name="type" value="Freelance" <%=(typeof query !=='undefined' &&
                                query.type && query.type.includes('Freelance')) ? 'checked' : '' %>>
                            Freelance
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%;">Apply Filters</button>
                    <% if (typeof query !=='undefined' && Object.keys(query).length> 0) { %>
                        <a href="/jobs" class="btn btn-outline"
                            style="width: 100%; text-align: center; display: block; margin-top: 0.5rem; text-decoration: none;">Clear
                            Filters</a>
                        <% } %>
                </form>
            </aside>

            <!-- JOB LISTINGS -->
            <main>
                <div class="job-listing-header">
                    <p>Showing <strong>
                            <%= jobs.length %>
                        </strong> jobs</p>
                    <select class="sort-select">
                        <option value="newest">Sort by: Newest First</option>
                        <option value="oldest">Sort by: Oldest</option>
                        <option value="salary-high">Salary: High to Low</option>
                    </select>
                </div>

                <div class="jobs-grid" style="grid-template-columns: 1fr; gap: 1.5rem;">
                    <% if (jobs && jobs.length> 0) { %>
                        <% jobs.forEach(job=> { %>
                            <div class="job-card"
                                style="display: flex; gap: 2rem; align-items: center; padding: 1.5rem;">
                                <div class="company-logo"
                                    style="width: 80px; height: 80px; font-size: 2rem; overflow: hidden;">
                                    <% if (job.employer && job.employer.profile && job.employer.profile.companyLogo) {
                                        %>
                                        <img src="<%= job.employer.profile.companyLogo %>" alt="Logo"
                                            style="width: 100%; height: 100%; object-fit: contain;">
                                        <% } else { %>
                                            <i data-lucide="briefcase"></i>
                                            <% } %>
                                </div>
                                <div style="flex: 1;">
                                    <div
                                        style="display: flex; justify-content: space-between; align-items: flex-start;">
                                        <div>
                                            <h3 style="font-size: 1.3rem; margin-bottom: 0.25rem;"><a
                                                    href="/job-detail/<%= job._id %>">
                                                    <%= job.title %>
                                                </a></h3>
                                            <span class="company-name"
                                                style="color: var(--color-primary); font-weight: 500;">
                                                <%= job.company %>
                                            </span>
                                        </div>
                                        <button
                                            style="background: none; border: none; color: var(--text-light); cursor: pointer;"><i
                                                data-lucide="bookmark"></i></button>
                                    </div>

                                    <div class="job-meta"
                                        style="flex-direction: row; gap: 1.5rem; margin-top: 1rem; margin-bottom: 1rem;">
                                        <span><i data-lucide="map-pin" style="width: 16px;"></i>
                                            <%= job.location %>
                                        </span>
                                        <span><i data-lucide="clock" style="width: 16px;"></i>
                                            <%= new Date(job.postedAt).toLocaleDateString() %>
                                        </span>
                                        <span style="font-weight: 600; color: var(--text-dark);">
                                            <%= job.salary || 'Competitive' %>
                                        </span>
                                    </div>

                                    <div class="job-badges">
                                        <span class="badge badge-blue">
                                            <%= job.type %>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div
                                        style="text-align: center; padding: 5rem 2rem; background: var(--bg-white); border-radius: var(--radius-lg); border: 1px dashed var(--border-color); grid-column: 1 / -1;">
                                        <div
                                            style="width: 80px; height: 80px; background: var(--bg-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: var(--text-light);">
                                            <i data-lucide="search" style="width: 40px; height: 40px;"></i>
                                        </div>
                                        <h3 style="color: var(--text-dark); margin-bottom: 0.5rem;">No jobs found</h3>
                                        <p style="color: var(--text-light); margin-bottom: 1.5rem;">We couldn't find any
                                            jobs matching your current filters. Try adjusting your search or keywords.
                                        </p>
                                        <a href="/jobs" class="btn btn-outline">Clear All Filters</a>
                                    </div>
                                    <% } %>
                </div>

                <!-- Pagination -->
                <div style="display: flex; justify-content: center; gap: 0.5rem; margin-top: 3rem;">
                    <button class="btn btn-outline" style="padding: 0.5rem 1rem;">Prev</button>
                    <button class="btn btn-primary" style="padding: 0.5rem 1rem;">1</button>
                    <button class="btn btn-outline" style="padding: 0.5rem 1rem;">2</button>
                    <button class="btn btn-outline" style="padding: 0.5rem 1rem;">3</button>
                    <button class="btn btn-outline" style="padding: 0.5rem 1rem;">Next</button>
                </div>

            </main>

        </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col" style="grid-column: span 1;">
                    <a href="/" class="brand-logo-container" style="align-items: flex-start; margin-bottom: 1.5rem;">
                        <svg class="brand-wave" viewBox="0 0 40 10" xmlns="http://www.w3.org/2000/svg"
                            style="left: 35%;">
                            <path d="M0 8 Q 10 0, 20 5 T 40 5 L 40 10 Q 30 10, 20 5 T 0 10 Z" />
                        </svg>
                        <div class="footer-brand">JOB<span>WHISPER</span></div>
                        <div class="footer-logo-text">Moving Brains</div>
                    </a>
                    <p style="margin-top: 1rem;">Your ultimate destination for finding your dream job. We connect talent
                        with opportunities worldwide safely and intuitively.</p>
                </div>
                <div class="footer-col footer-links">
                    <h4>For Candidates</h4>
                    <ul>
                        <li><a href="/jobs">Browse Jobs</a></li>
                        <li><a href="/candidate-dashboard">Candidate Dashboard</a></li>
                    </ul>
                </div>
                <div class="footer-col footer-links">
                    <h4>For Employers</h4>
                    <ul>
                        <li><a href="/post-job">Post a Job</a></li>
                        <li><a href="/employer-dashboard">Employer Dashboard</a></li>
                    </ul>
                </div>
                <div class="footer-col footer-links">
                    <h4>About Us</h4>
                    <ul>
                        <li><a href="/contact">Contact Us</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 JobWhisper.co.ke. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="js/main.js"></script>
    <script>lucide.createIcons();</script>
    </body>

    </html>
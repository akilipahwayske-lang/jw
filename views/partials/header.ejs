<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JobWhisper - Moving Brains | Find Your Dream Job</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/favicon.png">

    <!-- CSS -->
    <link rel="stylesheet" href="/css/styles.css">

    <!-- Icons (Lucide via CDN) -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>

    <!-- ================= NAVBAR ================= -->
    <nav class="navbar">
        <div class="container">
            <!-- Logo -->
            <a href="/" class="brand-logo-container" style="padding-top: 0;">
                <img src="/images/logo-header.png" alt="JobWhisper" style="height: 60px; object-fit: contain;">
            </a>

            <!-- Desktop Links -->
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/jobs">Find Jobs</a>
                <a href="#">Career Advice</a>
                <a href="/employer-dashboard">Employers</a>
                <a href="/contact">Contact</a>
            </div>

            <!-- Actions -->
            <div class="nav-actions">
                <% if (typeof user !=='undefined' && user) { %>
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <a href="<%= user.role === 'employer' ? '/employer-dashboard' : '/candidate-dashboard' %>"
                            class="user-avatar"
                            style="width: 40px; height: 40px; font-size: 1rem; border: 2px solid var(--color-primary); cursor: pointer; text-decoration: none;">
                            <% if (user.role==='employer' && user.profile.companyLogo) { %>
                                <img src="<%= user.profile.companyLogo %>" alt="Logo"
                                    style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                                <% } else { %>
                                    <%= (user.username ? user.username.charAt(0) : 'U' ).toUpperCase() %>
                                        <% } %>
                        </a>
                        <a href="/logout" class="btn btn-outline"
                            style="min-width: unset; padding: 0.4rem 0.8rem; font-size: 0.85rem;">Logout</a>
                    </div>
                    <% if (user.role==='employer' ) { %>
                        <a href="/post-job" class="btn btn-primary"
                            style="padding: 0.4rem 1rem; font-size: 0.85rem;">Post Job</a>
                        <% } %>
                            <% } else { %>
                                <a href="/login" class="btn btn-outline">Sign In</a>
                                <a href="/signup" class="btn btn-primary">Sign Up</a>
                                <% } %>
                                    <button class="mobile-menu-btn" id="mobileMenuBtn">
                                        <i data-lucide="menu"></i>
                                    </button>
            </div>
        </div>
    </nav>
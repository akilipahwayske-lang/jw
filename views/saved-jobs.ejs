<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Saved Jobs - JobWhisper</title>
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>
    <div class="dashboard-layout">
        <%- include('partials/dashboard-sidebar', { activePage: 'saved' }) %>

            <main class="dash-main">
                <%- include('partials/dashboard-header', { title: 'Saved Jobs' }) %>

                    <div class="dash-content">
                        <div
                            style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem;">
                            <div>
                                <h1 class="dash-title">Saved Jobs</h1>
                                <p class="dash-subtitle" style="margin-bottom: 0;">Jobs you've bookmarked for later.</p>
                            </div>
                            <a href="/jobs" class="btn btn-primary"><i data-lucide="search"></i> Browse Jobs</a>
                        </div>

                        <div class="jobs-grid" style="grid-template-columns: 1fr; gap: 1.5rem;">
                            <% if (savedJobs && savedJobs.length> 0) { %>
                                <% savedJobs.forEach(job=> { %>
                                    <div class="job-card"
                                        style="display: flex; gap: 1.5rem; align-items: center; padding: 1.5rem;">
                                        <div class="company-logo" style="width: 65px; height: 65px; font-size: 1.5rem;">
                                            <i data-lucide="briefcase"></i>
                                        </div>
                                        <div style="flex: 1;">
                                            <h3 style="font-size: 1.15rem; margin-bottom: 0.2rem;">
                                                <a href="/job-detail/<%= job._id %>"
                                                    style="color: var(--text-dark); text-decoration: none;">
                                                    <%= job.title %>
                                                </a>
                                            </h3>
                                            <span
                                                style="color: var(--color-primary); font-weight: 500; font-size: 0.9rem;">
                                                <%= job.company %>
                                            </span>
                                            <div class="job-meta"
                                                style="flex-direction: row; gap: 1.5rem; margin-top: 0.75rem;">
                                                <span><i data-lucide="map-pin" style="width: 14px;"></i>
                                                    <%= job.location %>
                                                </span>
                                                <span class="badge badge-blue">
                                                    <%= job.type %>
                                                </span>
                                                <span style="font-weight: 600;">
                                                    <%= job.salary || 'Competitive' %>
                                                </span>
                                            </div>
                                        </div>
                                        <div
                                            style="display: flex; flex-direction: column; gap: 0.5rem; flex-shrink: 0;">
                                            <a href="/job-detail/<%= job._id %>" class="btn btn-primary"
                                                style="padding: 0.5rem 1rem; font-size: 0.88rem; text-decoration: none;">View
                                                Job</a>
                                            <form action="/job/save/<%= job._id %>" method="POST">
                                                <button type="submit" class="btn btn-outline"
                                                    style="width: 100%; padding: 0.5rem 1rem; font-size: 0.88rem;">
                                                    <i data-lucide="bookmark-x" style="width: 14px;"></i> Unsave
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                    <% }) %>
                                        <% } else { %>
                                            <div
                                                style="text-align: center; padding: 5rem 2rem; background: var(--bg-white); border-radius: var(--radius-lg); border: 1px dashed var(--border-color);">
                                                <div
                                                    style="width: 70px; height: 70px; background: var(--bg-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: var(--text-light);">
                                                    <i data-lucide="bookmark" style="width: 35px; height: 35px;"></i>
                                                </div>
                                                <h3 style="color: var(--text-dark); margin-bottom: 0.5rem;">No saved
                                                    jobs yet</h3>
                                                <p style="color: var(--text-light); margin-bottom: 1.5rem;">Click the
                                                    "Save Job" button on any listing to bookmark it for later.</p>
                                                <a href="/jobs" class="btn btn-primary">Browse Jobs</a>
                                            </div>
                                            <% } %>
                        </div>
                    </div>
            </main>
    </div>

    <script src="js/main.js"></script>
    <script>lucide.createIcons();</script>
</body>

</html>